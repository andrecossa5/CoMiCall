// Configs
includeConfig 'config/pipeline.info.config'
includeConfig 'config/base.config'

// Parameters (defaults)
params {

    // Input/Output
    input_folder  = null
    individual    = null
    output_folder = null

    // Reference
    ref           = null   // faidx-indexed fasta containing chrM (used by make_tables, mpileup)
    masked_ref    = null   // NUMT-masked full-genome fasta, bwa-indexed (see code/mask_numts.sh);
                           // only required when single_molecule=true (REALIGN_MT_READS)

    // Quality / depth thresholds (shared by both modes)
    region        = "chrM"
    min_mq        = 30
    min_bq        = 30
    max_depth     = 100000
    max_idepth    = 100000
    max_softclip  = 0.1

    // Single-molecule mode
    single_molecule = true

    // Help
    help    = false
    version = false

}


//
