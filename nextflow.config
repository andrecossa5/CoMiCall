// Configs
includeConfig 'config/pipeline.info.config'
includeConfig 'config/base.config'

// Parameters (defaults)
params {

    // Input/Output
    input_folder  = null
    individual    = null
    output_folder = null

    // Reference
    ref           = null   // faidx-indexed fasta containing chrM (used by make_tables)
    masked_ref    = null   // NUMT-masked full-genome fasta, bwa-indexed (see code/mask_numts.sh)
                           // (REALIGN_MT_READS target)

    // Quality / depth thresholds
    min_mq        = 30
    min_bq        = 30
    max_softclip  = 0.1

    // FILTER_MUTS thresholds
    min_strand_ratio         = 0.1
    max_strand_ratio         = 10
    af_threshold             = 0.01
    min_callable_coverage    = 10
    max_sb_pval              = 0.05
    max_prevalence_low_AF    = 0.25
    min_gs_count_low_AF      = 1
    min_overlap_count_low_AF = 1
    min_n_mutations          = 1

    // GENOTYPE_MT thresholds
    gap_th           = 0.5
    min_total_counts = 3

    // Help
    help    = false
    version = false

}


//
